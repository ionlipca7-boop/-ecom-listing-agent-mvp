# ECOM OS V3 local sandbox env example
# Copy to .env only when needed. Do not commit real secrets.

# Local sandbox does not require secrets.
ECOM_OS_V3_MODE=local_sandbox
ECOM_OS_V3_NO_SERVER=1
ECOM_OS_V3_NO_LIVE_EBAY=1
ECOM_OS_V3_NO_DELETE=1

# Future Telegram adapter, not required for local test:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Future OpenAI/image adapter, not required for current local test:
# OPENAI_API_KEY=

# Future eBay dry/live adapter, not required for current local test:
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_REFRESH_TOKEN=
